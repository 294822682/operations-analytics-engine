    "issue_type": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "override_id": {
      "type": "string"
    },
    "business_subject_key": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "lead_id": {
      "type": "string"
    },
    "detected_stage": {
      "type": "string"
    },
    "message_cn": {
      "type": "string"
    },
    "suggested_action": {
